{
  "outputDirectory": "public",
  "functions": {
    "api/tweets.py": {
      "maxDuration": 120
    }
  },
  "headers": [
    {
      "source": "/api/price(.*)",
      "headers": [
        { "key": "Cache-Control", "value": "s-maxage=300, stale-while-revalidate=60" }
      ]
    },
    {
      "source": "/api/news(.*)",
      "headers": [
        { "key": "Cache-Control", "value": "s-maxage=180, stale-while-revalidate=60" }
      ]
    },
    {
      "source": "/api/tweets(.*)",
      "headers": [
        { "key": "Cache-Control", "value": "s-maxage=900, stale-while-revalidate=300" }
      ]
    },
    {
      "source": "/api/moving_averages",
      "headers": [
        { "key": "Cache-Control", "value": "s-maxage=600, stale-while-revalidate=120" }
      ]
    }
  ]
}
